# BrowserStack account credentials — get these from
# https://www.browserstack.com/accounts/settings. Referenced by every
# browserstack*.yml file's envFile: key, not loaded by config/loadEnv.ts (those only
# run inside our own Node/TS code; the BrowserStack SDK itself reads this file before
# Playwright even starts).
BROWSERSTACK_USERNAME=your-browserstack-username
BROWSERSTACK_ACCESS_KEY=your-browserstack-access-key
