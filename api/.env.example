# Optional: base URL for API tests. Defaults to https://api.restful-api.dev (a free public test API) if unset.
API_BASE_URL=https://api.restful-api.dev

# Optional: base URL for reqres.in tests. Defaults to https://reqres.in if unset.
REQRES_BASE_URL=https://reqres.in

# Required for reqres-user.spec.ts: reqres.in now requires a free API key on every
# endpoint. Get one at https://app.reqres.in/api-keys and paste it here.
REQRES_API_KEY=your-reqres-api-key
