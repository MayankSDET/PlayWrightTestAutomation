AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET_NAME=your-bucket-name

AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=your-container-name

# Optional: base URL for API tests. Defaults to https://api.restful-api.dev (a free public test API) if unset.
API_BASE_URL=https://api.restful-api.dev

# Optional: path to a SQLite file for DB tests. Defaults to an in-memory database (:memory:) if unset.
# Set to a real path (e.g. ./data/test.db) to test against a persistent SQLite file instead.
DB_FILE_PATH=:memory:
